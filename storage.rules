rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /catReports/{reportId}/{fileName} {
      allow read: if true;
      allow write: if request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType in ['image/jpeg', 'image/png', 'image/webp'];
    }
  }
}
